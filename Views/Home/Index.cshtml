@model HomeViewModel
@{
    ViewData["Title"] = "Catálogo de productos";
}

<div class="mb-4 row row-cols-2">
    <div class="col-6">
    <h1 class="display-5 fw-bold">Catálogo de productos</h1>
        <p class="text-muted mb-0">Explora los productos disponibles en nuestra tienda.</p>
    </div>

    <div class="col-6 d-flex justify-content-end">
        <button type="button" class="btn btn-primary me-2" data-bs-toggle="modal" data-bs-target="#exampleModal">Nuevo Producto</button>
    </div>
</div>

@if (Model.Productos.Count == 0)
{
    <div class="alert alert-info" role="alert">
        No hay productos disponibles por el momento.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var producto in Model.Productos)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(producto.Imagen))
                    {
                        <img src="@producto.Imagen" class="card-img-top" alt="@producto.Nombre" style="height: 200px; object-fit: cover;">
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@producto.Nombre</h5>
                            @if (producto.Categoria is not null)
                            {
                                <span class="badge text-bg-secondary">@producto.Categoria.Nombre</span>
                            }
                        </div>
                        <p class="card-text text-muted flex-grow-1">@producto.Descripcion</p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fs-5 fw-semibold text-primary">@producto.Precio.ToString("C")</span>
                            @if (producto.Stock > 0)
                            {
                                <span class="badge text-bg-success">@producto.Stock en stock</span>
                            }
                            else
                            {
                                <span class="badge text-bg-danger">Agotado</span>
                            }
                        </div>
                        <div class="d-flex justify-content-end mt-2">
                            <button class="btn btn-primary">Editar</button>
                            <button class="btn btn-danger ms-2">Eliminar</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLabel">Nuevo producto</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        ...
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary">Guardar</button>
      </div>
    </div>
  </div>
</div>